# Copy to .env.production ON THE BOX (gitignored). Next loads it for `npm start`.
NODE_ENV=production

# Score-poller auth — the GitHub Action sends this as x-admin-key. Use a long random string.
ADMIN_KEY=change-me-to-a-long-random-string

# Pool config — seeded into the DB on FIRST boot only (change later via the DB).
GROUP_NAME=Kitchen Table
GROUP_PASSCODE=kitchentable
LOCK_AT=2026-06-11T15:00:00-04:00
BUY_IN_CENTS=5000

# Bedrock (AI Mode) — Lightsail has no IAM instance role, so the box needs keys
# in its environment. Any IAM principal with bedrock:InvokeModel* works; reuse an
# existing key pair or mint one. Models used: Opus 4.6 / Sonnet 4.6 / Haiku 4.5
# (us-east-1, via global.* inference profiles — confirmed granted on this account).
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
